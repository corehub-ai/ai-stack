# ── Segredos (gerar com: openssl rand -hex 32) ─────────────────────────
BETTER_AUTH_SECRET=
MANIFEST_ENCRYPTION_KEY=
POSTGRES_PASSWORD=

# ── URL que o NAVEGADOR usa para abrir o dashboard ─────────────────────
# Precisa casar com a origem do browser, senão o login falha ("Invalid origin").
# Acesso pela LAN: http://<ip-da-maquina>:2099
MANIFEST_PUBLIC_URL=http://localhost:2099

# ── Profiles ativos ───────────────────────────────────────────────────
# local-models = serviço ollama interno (provedor local, sem credenciais).
# Acrescente ",ui" para subir o Open WebUI junto (ex.: local-models,ui).
COMPOSE_PROFILES=local-models

# ── Gateway (F2) — auth LAN ──────────────────────────────────────────
# Deixe vazio (padrão seguro): só loopback (127.0.0.1/::1) entra sem chave.
# NÃO coloque a subnet do compose (172.28.1.0/24) aqui — o docker-proxy
# (userland-proxy) faz hairpin do tráfego loopback do host pro IP do
# gateway da bridge, então qualquer processo no host passaria pela CIDR
# sem credencial (achado 2026-07-03, confirmado empiricamente). Só ligue
# isso sabendo do risco (ex.: --userland-proxy=false no daemon do Docker).
GATEWAY_TRUSTED_CIDRS=
GATEWAY_CORS_ORIGINS=
# Porta host do gateway. 11434 é o padrão (emula a porta default do Ollama
# para os clientes acharem sozinhos). Só mude se a máquina já tiver um
# Ollama nativo ocupando 11434 (ex.: GATEWAY_HOST_PORT=21434).
GATEWAY_HOST_PORT=11434

# ── Open WebUI (profile ui) — segredo da sessão da UI ─────────────────
WEBUI_SECRET_KEY=

# ── Chaves de agente do manifest (criadas no dashboard — Task 2) ───────
MANIFEST_KEY_OPENCODE=
MANIFEST_KEY_CLAUDE_CODE=
MANIFEST_KEY_COPILOT=
MANIFEST_KEY_OPENWEBUI=
MANIFEST_KEY_LAN_ANON=
# Agente dedicado só pra chamada de classificação do tier-classifier (spec
# docs/superpowers/specs/2026-07-04-tier-classifier-design.md D6) — criar no
# dashboard do manifest e configurar sua tier default apontando pro Ollama local.
MANIFEST_KEY_TIER_CLASSIFIER=
# Agente dedicado pro caller anônimo/confiável da façade Ollama do gateway
# (/api/chat, /api/generate -- spec docs/superpowers/specs/2026-07-05-ollama-facade-harness-design.md).
# Cliente que já manda sua própria credencial não é afetado. Vazio até criar
# o harness no dashboard do manifest: cai no MANIFEST_KEY_LAN_ANON acima
# (mesmo comportamento de hoje).
MANIFEST_KEY_OLLAMA_FACADE=
# Nome da tier a pedir nessa chamada (default "default") e timeout em ms antes
# do fail-open (default 1500) -- descomente pra sobrescrever os defaults do
# docker-compose.yml. CLASSIFIER_COLD_LOAD_EXTRA_MS: se a 1a tentativa
# estourar o timeout (sintoma de cold-load do modelo local), tenta 1 vez a
# mais com timeoutMs + esse valor antes de desistir (default 15000 = 15s).
# CLASSIFIER_CANONICALIZE (default true): remove temperature/top_p/top_k/thinking
# de todo request antes do forward -- o manifest é dono desses params por tier;
# evita o 400 da Anthropic (temperature≠1 + thinking). Ponha "false" pra desligar.
# CLASSIFIER_CANONICALIZE_BYPASS: chaves de harness cujas requests pulam a
# canonização (casado pela credencial da request, não pelo nome do harness). No
# docker-compose.yml já vem defaultado pra chave do Claude-Gateway
# (${MANIFEST_KEY_CLAUDE_CODE}) -- edite aquela linha pra bypassar outros.
# CLASSIFIER_MAX_INPUT_CHARS (default 6000): trunca a mensagem antes de
# classificar. Impede que mensagem grande estoure a janela de contexto do modelo
# (qwen2.5:3b=4096 tok) e faça o classificador responder o conteúdo em vez de
# classificar. Suba se usar um modelo de contexto maior e quiser mais sinal.
# CLASSIFIER_TIER=default
# CLASSIFIER_TIMEOUT_MS=1500
# CLASSIFIER_COLD_LOAD_EXTRA_MS=15000
# CLASSIFIER_CANONICALIZE=true
# CLASSIFIER_MAX_INPUT_CHARS=6000
